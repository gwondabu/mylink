rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 프로필 규칙
    match /users/{userId} {
      allow read: if true; // 누구나 읽기 가능
      allow create, update: if request.auth != null && request.auth.uid == userId; // 로그인된 본인만 생성/수정 가능
      allow delete: if false; // 프로필 삭제 방지
    }

    // 사용자 하위 링크 서브컬렉션 규칙
    match /users/{userId}/links/{linkId} {
      allow read: if true; // 누구나 링크 목록 읽기 가능
      allow create, delete: if request.auth != null && request.auth.uid == userId; // 본인만 생성/삭제 가능
      // 업데이트: 본인이거나 또는 외부 유저가 title, url을 변경하지 않고 오직 clickCount만 1 증가시킬 때 허용
      allow update: if (request.auth != null && request.auth.uid == userId)
                    || (request.resource.data.title == resource.data.title 
                        && request.resource.data.url == resource.data.url 
                        && (request.resource.data.clickCount == resource.data.clickCount + 1 
                            || (resource.data.clickCount == null && request.resource.data.clickCount == 1)));
    }
  }
}

